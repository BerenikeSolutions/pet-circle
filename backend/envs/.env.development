# === PetCircle Backend — Development Environment ===
# Local development with debug mode.
# Replace placeholder values with your actual dev credentials.

APP_ENV=development

# === OpenAI ===
OPENAI_API_KEY=sk-your-dev-openai-key

# === Supabase (local or dev project) ===
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key
SUPABASE_BUCKET_NAME=petcircle-documents

# === WhatsApp Cloud API (test number) ===
WHATSAPP_TOKEN=your-dev-whatsapp-token
WHATSAPP_VERIFY_TOKEN=local-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-test-phone-id
WHATSAPP_APP_SECRET=your-dev-app-secret

# === WhatsApp Template Names ===
WHATSAPP_TEMPLATE_REMINDER=petcircle_reminder_v1
WHATSAPP_TEMPLATE_OVERDUE=petcircle_overdue_v1
WHATSAPP_TEMPLATE_NUDGE=petcircle_nudge_v1
WHATSAPP_TEMPLATE_CONFLICT=petcircle_conflict_v1
WHATSAPP_TEMPLATE_ONBOARDING_COMPLETE=petcircle_onboarding_complete_v1

# === Admin ===
ADMIN_SECRET_KEY=dev-admin-secret-replace-me
ADMIN_DASHBOARD_PASSWORD=dev-dashboard-password

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/petcircle_dev

# === Security ===
# Dev Fernet key — generate your own: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=qbjMqijHDi8XmK0GRfjGaRN4mXDW-6w2tHsA1jJmBSY=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
